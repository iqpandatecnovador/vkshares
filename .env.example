# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno. NO pongas valores reales aquí.
# Copia este archivo a `.env.local` y rellena con tus credenciales.
# `.env.local` está ignorado por git (.gitignore -> .env*).
# ─────────────────────────────────────────────────────────────

# HubSpot CRM (token de app privada)
HUBSPOT_ACCESS_TOKEN=

# Stripe — clave secreta de servidor (sk_test_... en dev, sk_live_... en prod)
STRIPE_SECRET_KEY=

# Stripe — clave publicable (pk_test_... / pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe — secreto de verificación de firma del webhook (whsec_...)
# Obténlo en: Stripe Dashboard > Developers > Webhooks, o con `stripe listen`
STRIPE_WEBHOOK_SECRET=

# URL base pública de la app (usada para success_url / cancel_url de Stripe)
# Ej: http://localhost:3000 en desarrollo, https://tudominio.com en producción
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Supabase Backend
# ─────────────────────────────────────────────────────────────
# URL de la base de datos Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública de Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de Service Role de Supabase (usada SOLO en backend para saltar RLS)
SUPABASE_SERVICE_ROLE_KEY=

